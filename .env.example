# Port, na kterém poběží Express server (Railway nastavuje vlastní PORT)
PORT=3000

# production zapne minifikaci, vypne debug logy atd.
NODE_ENV=production

# Cesta k SQLite databázi. Na Railway nasměruj na připojený Volume
# (např. /data/gardenpin.db), jinak se data ztratí při každém restartu.
# Když je prázdné, použije se default backend/data/zahrada.db.
DATABASE_PATH=

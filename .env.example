# Port, na kterém poběží Express server
PORT=3000

# Prostředí (production zapne minifikaci, vypne debug logy atp.)
NODE_ENV=production

# Cesta k SQLite databázi. Na Railway nasměrujte na připojený Volume,
# např. /data/gardenpin.db, jinak se data ztratí při každém restartu.
DATABASE_PATH=./data/gardenpin.db

# Web Push (VAPID) credentials. Generate with:
#   node -e "const w=require('web-push'); const k=w.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY='+k.publicKey); console.log('VAPID_PRIVATE_KEY='+k.privateKey);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Stripe — GardenPin Premium subscription
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Dashboard → Developers → Webhooks → vyber endpoint /api/premium/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard → Products → vyber Premium produkt → zkopíruj Price ID (recurring 99 Kč/měsíc)
STRIPE_PRICE_ID=price_...

# Base URL aplikace — používá se pro success_url / cancel_url v Checkout Session
FRONTEND_URL=http://localhost:3000

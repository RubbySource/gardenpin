# VAPID klíče pro Web Push notifikace.
# Vygeneruj nové: node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
# Server vygeneruje vlastní klíče při prvním startu, pokud .env chybí.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:patrik@gardenpin.local

# Stripe — GardenPin Premium (149 Kč/měsíc)
# 1. Vytvoř produkt + price v https://dashboard.stripe.com/products → zkopíruj price_xxx do STRIPE_PRICE_ID
# 2. STRIPE_SECRET_KEY = sk_test_... nebo sk_live_...
# 3. Webhook secret: stripe listen --forward-to localhost:3000/api/stripe/webhook (dev), nebo ho vygeneruj v dashboardu (prod)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Email připomínky — Gmail SMTP pro týdenní digest (pondělí 8:00).
# Gmail vyžaduje App Password (ne heslo k účtu!):
#   1. Zapni 2-Step Verification na https://myaccount.google.com/security
#   2. Vygeneruj App Password: https://myaccount.google.com/apppasswords
#   3. Zkopíruj 16-znakový kód (bez mezer) do GMAIL_APP_PASSWORD
GMAIL_FROM=
GMAIL_APP_PASSWORD=
